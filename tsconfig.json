{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["./src/*"],
      "@/shared/*": ["src/shared/*"],
      "@/features/*": ["src/features/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "src/features/accounts/components/account-empty-statetsx"
  ],
  "exclude": [
    "node_modules",
    "supabase/functions"
  ]
}